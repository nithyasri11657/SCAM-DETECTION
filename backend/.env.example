# Environment Configuration for Scam Detector Backend
# Copy this file to .env and update values

# FastAPI Settings
API_TITLE=Scam Detection Assistant API
API_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# Device Configuration
# Options: cuda, rocm, cpu
# AMD ROCm users: set DEVICE=rocm
# CPU only: DEVICE=cpu
# Auto-detect CUDA: leave empty or DEVICE=auto
DEVICE=auto

# Database
DATABASE_URL=sqlite+aiosqlite:///./scam_detector.db
DB_ECHO=False

# Model Settings
MODEL_NAME=distilbert-base-uncased
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
CACHE_DIR=./models_cache

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# PII Detection
ENABLE_PII_REDACTION=True
PII_DETECTION_ENGINE=presidio  # presidio or regex

# Explainability
ENABLE_LIME=True
ENABLE_SHAP=True
LIME_NUM_SAMPLES=500
SHAP_SAMPLE_SIZE=100

# API Settings
CORS_ORIGINS=["http://localhost:5173", "http://localhost:5174", "http://127.0.0.1:5173", "http://127.0.0.1:5174"]
MAX_CONTENT_LENGTH=2000

# Threat Intelligence
THREAT_PATTERNS_DIR=./data/threat_patterns

# Testing
TEST_MODE=False
